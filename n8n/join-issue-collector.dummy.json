    {
      "parameters": {
        "promptType": "define",
        "text": "=Du bist ein technischer Projektmanager für das Kanban-Board \"Join\". Analysiere den E-Mail-Text und extrahiere die Daten in JSON.\n\nE-Mail Betreff: {{ $('Email Trigger (IMAP)').item.json.subject }}\nE-Mail Text: {{ $('Email Trigger (IMAP)').item.json.text }}\n\nGib exakt dieses JSON-Format zurück:\n{\n  \"title\": \"Prägnanter Titel\",\n  \"category\": \"technischer Task, User Story/Feature, oder Bug Request\",\n  \"priority\": \"urgent, medium, oder low\",\n  \"deadline\": \"Deadline falls vorhanden, sonst null\",\n  \"description\": \"Fasse das Anliegen zusammen. Füge am Ende hinzu: 'Dieses Ticket wurde KI-generiert'\"\n}\n\nGib NUR das JSON aus.",
        "hasOutputParser": true
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.4,
      "position": [
        80,
        -80
      ],
      "id": "7786ef37-ea6f-4b8b-9e6b-b89086f9c371",
      "name": "Basic LLM Chain"
    },
